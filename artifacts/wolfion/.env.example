# ─────────────────────────────────────────────────────────────────
# Wolfion frontend — environment variables
# Copy to `.env.local` and fill in real values. NEVER commit `.env.local`.
# On Vercel/Netlify, set the same variables in the project dashboard
# (Settings → Environment Variables). All VITE_* vars are PUBLIC at
# runtime (baked into the bundle) — never put a server secret here.
# ─────────────────────────────────────────────────────────────────

# Clerk (your own Clerk account — see MIGRATION.md step 2)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: only set if you're using a Clerk proxy / custom domain.
# Leave UNSET for normal Clerk hosted setup.
# VITE_CLERK_PROXY_URL=

# Firebase web SDK config (safe to expose — they are public identifiers,
# RTDB rules + Firebase Auth are what protect your data)
VITE_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Where the backend lives. In production point this at your Render URL.
# Leave EMPTY for local dev and Vercel will rewrite /api/* to your backend
# via vercel.json.
VITE_API_BASE_URL=
