# ─────────────────────────────────────────────────────────────────
# Wolfion API server — environment variables
# Copy to `.env` for local dev (NEVER commit). On Render, set these
# under Environment → Environment Variables.
# ─────────────────────────────────────────────────────────────────

# Node runtime
NODE_ENV=production
PORT=8080

# Clerk (server-side, from your own Clerk dashboard → API keys)
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Firebase Admin SDK service account, the WHOLE JSON file as ONE LINE.
# Get it from Firebase Console → Project Settings → Service Accounts →
# Generate new private key. Paste the entire JSON content.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# Comma-separated list of admin emails (must match the emails of the
# Clerk users who should be allowed to write to the cloud DB).
WOLFION_ADMIN_EMAILS=you@example.com,co-admin@example.com

# Express session secret — any long random string (e.g. `openssl rand -hex 32`).
SESSION_SECRET=replace-with-a-long-random-string

# CORS: the frontend URL that's allowed to call this API.
# In production this is your Vercel URL (e.g. https://wolfion.vercel.app).
# For local dev set to http://localhost:5173.
CORS_ORIGIN=https://wolfion.vercel.app

# Optional: Groq API key (only if you use the AI assistant routes)
GROQ_API_KEY=
